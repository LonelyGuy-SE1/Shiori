{
  "manifest_version": 3,
  "name": "Shiori",
  "version": "0.1.0",
  "description": "Track anime watch progress and sync watched episodes to MyAnimeList.",
  "icons": {
    "16": "assets/icons/SE116.png",
    "32": "assets/icons/SE132.png",
    "48": "assets/icons/SE148.png",
    "128": "assets/icons/SE1128.png"
  },
  "permissions": [
    "activeTab",
    "identity",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://api.myanimelist.net/*",
    "https://api.jikan.moe/*",
    "https://myanimelist.net/*",
    "https://animepahe.com/*",
    "https://animepahe.ch/*",
    "https://animepahe.org/*",
    "https://animepahe.pw/*"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Shiori",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "assets/icons/SE116.png",
      "32": "assets/icons/SE132.png",
      "48": "assets/icons/SE148.png",
      "128": "assets/icons/SE1128.png"
    }
  }
}
